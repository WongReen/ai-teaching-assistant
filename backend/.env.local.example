# 本地开发环境配置（使用本地 MySQL，无需 Docker）
# 复制此文件为 .env.local 并使用

# ==========================================
# 应用基本配置
# ==========================================
APP_NAME=AI Teaching Assistant API
APP_VERSION=1.0.0
DEBUG=true
LOG_LEVEL=INFO

# ==========================================
# 服务器配置
# ==========================================
HOST=127.0.0.1
PORT=9000
WORKERS=1
RELOAD=true

# ==========================================
# 数据库配置（本地 MySQL）
# ==========================================
# 请确保本地 MySQL 已启动，并创建了数据库和用户
# 创建数据库SQL: CREATE DATABASE ai_teaching_assistant CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci;
# 创建用户SQL: CREATE USER 'ai_teaching'@'localhost' IDENTIFIED BY 'ai_teaching_dev';
# 授权SQL: GRANT ALL PRIVILEGES ON ai_teaching_assistant.* TO 'ai_teaching'@'localhost';
DATABASE_URL=mysql+aiomysql://ai_teaching:ai_teaching_dev@localhost:3306/ai_teaching_assistant
DATABASE_ECHO=false

# ==========================================
# RabbitMQ 配置（可选，本地开发可禁用）
# ==========================================
# 如果本地没有 RabbitMQ，留空即可，任务将同步执行
RABBITMQ_URL=

# ==========================================
# 安全配置
# ==========================================
SECRET_KEY=local-dev-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ==========================================
# CORS 跨域配置
# ==========================================
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# ==========================================
# AI/LLM 配置
# ==========================================
# 如果需要测试 AI 功能，请配置真实的 API 密钥
OPENAI_API_KEY=
OPENAI_API_BASE=https://api.openai.com/v1
AI_MODEL=gpt-4

# DeepSeek 配置（可选）
USE_DEEPSEEK=false
DEEPSEEK_API_KEY=

# ==========================================
# 文件上传配置
# ==========================================
MAX_UPLOAD_SIZE=10485760
UPLOAD_DIR=./uploads
UPLOAD_STORAGE_BACKEND=local

# ==========================================
# 其他配置
# ==========================================
RATE_LIMIT_ENABLED=false
ENABLE_REQUEST_LOGGING=true
ENABLE_FILE_LOGGING=false
ENABLE_PERFORMANCE_MONITORING=false
PRETTY_PRINT_LOGS=true
