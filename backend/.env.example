# AI Teaching Assistant backend env template
# Copy to backend/.env for local development.

# Application
APP_NAME="AI Teaching Assistant API"
APP_VERSION="1.0.0"
APP_DESCRIPTION="Backend API for AI-powered teaching assistant with automated grading and Q&A support"
DEBUG=true
LOG_LEVEL=INFO

# Server
HOST=0.0.0.0
PORT=8000
WORKERS=1
RELOAD=true

# CORS
CORS_ORIGINS=["http://localhost:3000", "http://127.0.0.1:3000", "http://localhost:3001", "http://localhost:3002"]
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=["*"]
CORS_ALLOW_HEADERS=["*"]

# API
API_V1_PREFIX=/api/v1

# OpenAI-compatible providers
OPENAI_API_KEY=
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_ORG_ID=
AI_MODEL=gpt-4
AI_TEMPERATURE=0.7
AI_MAX_TOKENS=2000
AI_TIMEOUT=30

# Optional local / FastChat backends
USE_LOCAL_LLM=false
LOCAL_LLM_MODEL_PATH=
USE_FASTCHAT=false
FASTCHAT_API_BASE=http://localhost:8000/v1
FASTCHAT_MODEL_NAME=qwen2.5-7b
FASTCHAT_TEMPERATURE=0.7
FASTCHAT_MAX_TOKENS=2000
FASTCHAT_TIMEOUT=60

# DeepSeek
USE_DEEPSEEK=false
DEEPSEEK_API_KEY=
DEEPSEEK_API_BASE=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_TEMPERATURE=0.7
DEEPSEEK_MAX_TOKENS=2000
DEEPSEEK_TIMEOUT=60
DEEPSEEK_MAX_RETRIES=3
DEEPSEEK_RETRY_DELAY=1.0

# Database
DATABASE_URL=mysql+aiomysql://ai_teaching:ai_teaching_dev@localhost:3306/ai_teaching_assistant
# DATABASE_URL=mysql+pymysql://ai_teaching:ai_teaching_dev@localhost:3306/ai_teaching_assistant
# DATABASE_URL=sqlite:///./teaching_assistant.db
DATABASE_ECHO=false

# Cache
REDIS_URL=
CACHE_TTL=3600

# Uploads and storage
MAX_UPLOAD_SIZE=10485760
UPLOAD_DIR=./uploads
UPLOAD_STORAGE_BACKEND=local
UPLOAD_S3_BUCKET=
UPLOAD_S3_REGION=
UPLOAD_S3_ENDPOINT_URL=
UPLOAD_S3_KEY_PREFIX=uploads
UPLOAD_S3_ACCESS_KEY_ID=
UPLOAD_S3_SECRET_ACCESS_KEY=
ALLOWED_EXTENSIONS=[".py", ".java", ".cpp", ".c", ".cc", ".cxx", ".js", ".jsx", ".ts", ".tsx", ".php", ".h", ".hpp", ".pdf", ".docx", ".txt"]

# Analysis
MAX_LINE_LENGTH=120
COMPLEXITY_THRESHOLD=10
MIN_MAINTAINABILITY_INDEX=20.0
PLAGIARISM_THRESHOLD=0.7
STORE_SUBMISSIONS=true

# Security
SECRET_KEY=change-this-in-production-use-a-secure-random-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
TOKEN_URL=/api/v1/auth/login

# Rate limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=60
