# ==========================================
# AI Teaching Assistant 生产环境配置示例
# ==========================================
# 部署前请复制此文件为 .env 并修改所有占位符

# ------------------------------------------
# 应用基本配置
# ------------------------------------------
APP_NAME=AI Teaching Assistant API
APP_VERSION=1.0.0
APP_DESCRIPTION=Backend API for AI-powered teaching assistant

# 生产环境必须关闭调试模式
DEBUG=false
LOG_LEVEL=INFO

# ------------------------------------------
# 服务器配置
# ------------------------------------------
HOST=0.0.0.0
PORT=9000
WORKERS=4
RELOAD=false

# ------------------------------------------
# 数据库配置（MySQL）
# ------------------------------------------
# 格式: mysql+aiomysql://用户名:密码@主机:端口/数据库名
DATABASE_URL=mysql+aiomysql://ai_teaching:your_secure_db_password@localhost:3306/ai_teaching_assistant
DATABASE_ECHO=false

# ------------------------------------------
# RabbitMQ 消息队列配置（可选）
# ------------------------------------------
RABBITMQ_URL=amqp://ai_ta:your_rabbitmq_password@localhost:5672/

# ------------------------------------------
# 安全配置（务必修改！）
# ------------------------------------------
# JWT 密钥 - 生产环境使用强随机字符串（至少 32 位）
SECRET_KEY=your-very-secure-random-secret-key-min-32-chars-long
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
TOKEN_URL=/api/v1/auth/login

# ------------------------------------------
# CORS 跨域配置
# ------------------------------------------
# 生产环境只允许特定域名访问
CORS_ORIGINS=["https://your-frontend-domain.com","https://www.your-frontend-domain.com"]
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=["GET","POST","PUT","DELETE","OPTIONS"]
CORS_ALLOW_HEADERS=["*"]

# ------------------------------------------
# AI/LLM 配置
# ------------------------------------------
# OpenAI 配置
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_ORG_ID=
AI_MODEL=gpt-4
AI_TEMPERATURE=0.7
AI_MAX_TOKENS=2000
AI_TIMEOUT=30

# DeepSeek 配置（可选）
USE_DEEPSEEK=false
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_API_BASE=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_TEMPERATURE=0.7
DEEPSEEK_MAX_TOKENS=2000

# 本地模型配置（可选）
USE_LOCAL_LLM=false
LOCAL_LLM_MODEL_PATH=/path/to/your/local/model
USE_FASTCHAT=false
FASTCHAT_API_BASE=http://localhost:8000/v1
FASTCHAT_MODEL_NAME=qwen2.5-7b

# ------------------------------------------
# 文件上传配置
# ------------------------------------------
MAX_UPLOAD_SIZE=10485760
UPLOAD_DIR=./uploads
UPLOAD_STORAGE_BACKEND=local
ALLOWED_EXTENSIONS=[".py",".java",".cpp",".c",".js",".jsx",".ts",".tsx",".php",".h",".hpp",".pdf",".docx",".txt"]

# S3 配置（如果使用 S3 存储）
UPLOAD_S3_BUCKET=your-s3-bucket
UPLOAD_S3_REGION=us-east-1
UPLOAD_S3_ACCESS_KEY_ID=your-access-key
UPLOAD_S3_SECRET_ACCESS_KEY=your-secret-key

# ------------------------------------------
# Redis/缓存配置（可选）
# ------------------------------------------
REDIS_URL=redis://localhost:6379/0
CACHE_TTL=3600

# ------------------------------------------
# 限流配置
# ------------------------------------------
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=60

# ------------------------------------------
# 日志配置
# ------------------------------------------
ENABLE_REQUEST_LOGGING=true
ENABLE_FILE_LOGGING=true
ENABLE_PERFORMANCE_MONITORING=true
PRETTY_PRINT_LOGS=false

# ------------------------------------------
# 代码分析配置
# ------------------------------------------
MAX_LINE_LENGTH=120
COMPLEXITY_THRESHOLD=10
MIN_MAINTAINABILITY_INDEX=20.0

# ------------------------------------------
# 抄袭检测配置
# ------------------------------------------
PLAGIARISM_THRESHOLD=0.7
STORE_SUBMISSIONS=true
